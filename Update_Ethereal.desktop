[Desktop Entry]
Type=Application
Name=🪐 Update EtherealOS
Comment=Fetch latest system patches from GitHub
Exec=bash -c "if [ -d ~/ethereal-update ]; then cd ~/ethereal-update && git pull; else rm -rf ~/ethereal-update 2>/dev/null; git clone https://github.com/abdallah2008xx-jpg/EtherealOS-Core.git ~/ethereal-update; fi && cd ~/ethereal-update && bash Ethereal-Update.sh"
Icon=/home/abdallah/.local/share/icons/ethereal/ethereal-update.svg
Terminal=false
Categories=System;Settings;
Keywords=update;patch;ethereal;
